# DealRail backend environment example
#
# Canonical production server for the current product:
#   node dist/index-simple.js
#
# Railway notes:
# - Set Root Directory to `backend` if using monorepo deploys
# - Build command: `npm install && npm run build`
# - Start command: `node dist/index-simple.js`
# - Railway usually injects PORT automatically

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------

NODE_ENV="production"
HOST="0.0.0.0"
PORT="3001"

# Active default chain for health and lifecycle reads when no chain is specified.
ACTIVE_CHAIN="baseSepolia"

# -----------------------------------------------------------------------------
# Required chain access
# -----------------------------------------------------------------------------

BASE_SEPOLIA_RPC="https://sepolia.base.org"
CELO_SEPOLIA_RPC="https://forno.celo-sepolia.celo-testnet.org"

# Wallets used by the backend-backed lifecycle actions.
# Rotate these if they were ever exposed.
DEPLOYER_PRIVATE_KEY="0x..."
AGENT_PRIVATE_KEY="0x..."
EVALUATOR_PRIVATE_KEY="0x..."

# -----------------------------------------------------------------------------
# Canonical contract addresses
# These are optional because backend/src/config.ts already provides defaults.
# Set them explicitly in Railway if you want configuration clarity.
# -----------------------------------------------------------------------------

# Base Sepolia
ESCROW_RAIL_BASE_SEPOLIA="0x8c55C2BB6A396D3654f214726230D81e6fa22b69"
ESCROW_RAIL_ERC20_BASE_SEPOLIA="0xE25B10057556e9714d2ac60992b68f4E61481cF9"
DEALRAIL_HOOK_BASE_SEPOLIA="0x5fA109A74a688a49D254a21C2F3ab238E2A7F62e"
ERC8004_VERIFIER_BASE_SEPOLIA="0xDB23657606957B32B385eC0A917d2818156668AC"
NULL_VERIFIER_BASE_SEPOLIA="0xA61a57fF5570bF989a3a565B87b6421413995317"

# Celo Sepolia
ESCROW_RAIL_CELO_SEPOLIA="0x684D32E03642870B88134A3722B0b094666EF42e"
ESCROW_RAIL_ERC20_CELO_SEPOLIA="0xB9dfa53326016415ca6fb9eb16A0f050c8d15C74"
DEALRAIL_HOOK_CELO_SEPOLIA="0x04B0D16f790A5F83dc48c7e4D05467ff2eA57519"
ERC8004_VERIFIER_CELO_SEPOLIA="0x2700e5B26909301967DFeECE9cb931B9bA3bA2df"
CELO_SEPOLIA_STABLE_TOKEN="0x01C5C0122039549AD1493B8220cABEdD739BC44E"

# -----------------------------------------------------------------------------
# Optional current integrations
# Keep mock mode on unless you are intentionally enabling live external services.
# -----------------------------------------------------------------------------

# x402n bridge
X402N_BASE_URL="https://x402n.kairen.xyz/api/v1"
X402N_API_KEY=""
X402N_MOCK_MODE="true"
X402N_CATEGORY_ID=""

# Locus MCP bridge
LOCUS_MCP_URL="https://mcp.paywithlocus.com/mcp"
LOCUS_API_KEY=""
LOCUS_MOCK_MODE="true"
LOCUS_SEND_USDC_TOOL="send_usdc"

# Neutral discovery adapters
DISCOVERY_X402N_ENABLED="true"
DISCOVERY_VIRTUALS_ENABLED="false"
DISCOVERY_NEAR_ENABLED="false"
DISCOVERY_VIRTUALS_SERVICES_URL=""
DISCOVERY_NEAR_SERVICES_URL=""
DISCOVERY_TIMEOUT_MS="3500"

# -----------------------------------------------------------------------------
# Optional reference and downstream integrations
# -----------------------------------------------------------------------------

# Uniswap integration
BASE_MAINNET_RPC="https://mainnet.base.org"
UNISWAP_QUOTER_V2_BASE="0x3d4e44Eb1374240CE5F1B871ab261CD16335B76a"
UNISWAP_SWAP_ROUTER_02_BASE="0x2626664c2603336E57B271c5C0b26F421741e481"
UNISWAP_UNIVERSAL_ROUTER_BASE="0x3fC91A3afd70395Cd496C647d5a6CC9D4B2b7FAD"

# ERC-8004 identity and reputation registries
ERC8004_IDENTITY_REGISTRY="0x8004A169FB4a3325136EB29fA0ceB6D2e539a432"
ERC8004_REPUTATION_REGISTRY="0x8004BAa17C55a88189AE136b182e5fdA19dE9b63"

# Optional Bankr configuration
BANKR_API_KEY=""
BANKR_API_URL="https://api.bankr.bot"

# Optional Pinata configuration
PINATA_JWT=""
PINATA_GATEWAY="https://gateway.pinata.cloud"

# -----------------------------------------------------------------------------
# Database
# Not required for the canonical index-simple Railway deployment.
# Keep empty unless you are using database-backed paths elsewhere in the repo.
# -----------------------------------------------------------------------------

DATABASE_URL=""
